---
import { Image } from "astro:assets";

import MobileMenu from "./MobileMenu.astro";

import OatUnderline from "./OatUnderline.astro";

import { cn } from "@/lib/utils";
import { links } from "@/lib/data";

const pathname = Astro.url.pathname;
