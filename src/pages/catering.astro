---
import { Image } from "astro:assets";

import { Icon } from "astro-icon/components";

import Layout from "@/layouts/Layout.astro";

import { CateringForm } from "@/components/pages/catering/catering-form.tsx";
---

<Layout title="Catering" full>
  <!-- Hero -->
  <div class="relative">
    <Image
      id="logo"
      src={import("../assets/img/pages/catering/hero.jpg")}
      width="1550"
      alt="catering hero"
      class="mx-auto h-auto max-h-[600px] w-full object-cover"
      loading="eager"
    />

    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/50 via-black/30 to-transparent"
    >
    </div>

    <div class="relative mx-auto max-w-4xl xl:max-w-7xl">
      <div class="absolute bottom-5 left-5 z-10 font-sans text-white">
        <h2 class="font-fancy text-9xl text-shadow-lg">Lock in</h2>
        <p class="mt-3 font-serif text-3xl">
          —good food, and carefree experience await!
        </p>
      </div>
    </div>
  </div>

  <!-- Booking Disclaimer -->
  <div class="relative">
    <div
      class="absolute inset-0 -z-10 bg-cover bg-center"
      style="background-image: url('/pages/catering/booking-disclaimer.jpg');"
    >
    </div>

    <div
      class="relative z-10 my-10 flex flex-col justify-center gap-10 p-5 text-white"
    >
      <div
        class="mx-auto max-w-7xl space-y-6 rounded-3xl bg-gray-300 p-10 text-3xl text-black"
      >
        <h2 class="text-center font-serif text-6xl font-medium text-black">
          Booking disclaimer
        </h2>

        <p>
          All catering orders are <strong class="font-bold">request-only</strong
          >—we do our very best to accommodate your needs.
        </p>

        <p class="text-center font-bold">Please note:</p>

        <ul class="ml-8 list-disc">
          <li>
            We require a <strong class="font-bold">5-day advance notice</strong>
            for all requests
          </li>
          <li>
            <strong class="font-bold"
              >Guest allergens must be shared 48 hours before</strong
            > your booking
          </li>
          <li>
            For events <strong class="font-bold">outside the cafe</strong>, room
            bookings must first be confirmed through the <strong
              class="font-bold">Ākau Tangi Sports Centre</strong
            >—catering requests cannot be approved until this is done
          </li>
        </ul>

        <p class="text-center">
          One of our team members will review your booking and be in contact
          with you shortly.<br />We look forward to making your event a success!
        </p>
      </div>
    </div>
  </div>

  <!-- Catering Form -->
  <div class="relative">
    <div
      class="absolute inset-0 -z-10 bg-cover bg-center"
      style="background-image: url('/pages/catering/catering-form.jpg');"
    >
    </div>

    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/75 via-black/50 to-transparent"
    >
    </div>

    <div
      class="relative z-10 my-10 flex flex-col justify-center gap-10 p-5 text-white"
    >
      <div
        class="mx-auto w-full max-w-7xl space-y-6 rounded-3xl bg-black p-10 text-3xl"
      >
        <h2 class="font-serif text-3xl font-medium text-amber-50">
          Book your beat
        </h2>

        <CateringForm client:visible />
      </div>
    </div>
  </div>
</Layout>
