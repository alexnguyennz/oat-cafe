---
import { Image } from "astro:assets";

import { Button } from "@heroui/react";

import Layout from "@/layouts/Layout.astro";

import { Gallery } from "@/components/pages/about/gallery.tsx";
---

<Layout title="About" full>
  <div
    class="flex w-full max-w-4xl flex-1 flex-col justify-center gap-6 self-center rounded-3xl px-5 text-black xl:max-w-7xl"
  >
    <div class="grid items-center gap-6 pt-24 text-white">
      <div class="hero space-y-6">
        <Image
          id="logo"
          src={import("../assets/img/logo.png")}
          width="550"
          alt="Oat Café logo"
          class="mx-auto h-auto object-cover"
          loading="eager"
        />
      </div>
    </div>

    <div class="space-y-6 rounded-3xl bg-white p-10">
      <h2
        class="text-primary-brown text-center font-serif text-6xl font-medium text-balance"
      >
        Our dedication to you
      </h2>
      <p
        class="text-primary-brown/75 mx-auto max-w-5xl text-center font-serif text-4xl leading-12 font-medium text-balance"
      >
        At Oat Café, we pride ourselves on being more than just a place to grab
        a quick bite — we are a family-friendly and child-friendly destination
        where friends gather, and memories are made.
      </p>
    </div>

    <div class="space-y-6">
      <h2
        class="text-center font-serif text-6xl font-medium text-balance text-white text-shadow-lg"
      >
        View our venue
      </h2>

      <Gallery client:visible />
    </div>
  </div>

  <div class="bg-black">
    <h2
      class="text-center font-serif text-6xl font-medium text-balance text-white text-shadow-lg"
    >
      Oat Café is proudly owned by Yellow Seat
    </h2>
    <div class="space-y-6 rounded-3xl bg-neutral-800 p-10">
      <p
        class="mx-auto max-w-5xl text-center font-serif text-4xl leading-12 font-medium text-balance text-white"
      >
        Yellow Seat was founded out of a love of cuisine, our passion for
        service, and a drive to excel in the industry. We take great pleasure in
        being able to produce almost any delectable dish you can think of and
        deliver it with unmatched service.
      </p>
    </div>
  </div>
</Layout>

<style>
  body {
    background:
      linear-gradient(rgba(0, 0, 0, 0), rgba(0, 0, 0, 0)),
      url("/pages/about.jpg") center/cover no-repeat;
  }
</style>
