---
import Layout from "@/layouts/Layout.astro";

import Input from "@/components/ui/Input.astro";
import Textarea from "@/components/ui/Textarea.astro";
import Button from "@/components/ui/Button.astro";

import { ContactForm } from "@/components/contact-form";
---

<Layout title="Contact" orientation="top-left">
  <h1>Contact</h1>

  <div class="grid gap-6">
    <iframe
      title="Google Maps location"
      width="100%"
      height="400"
      style="border:0"
      referrerpolicy="no-referrer-when-downgrade"
      src={`https://www.google.com/maps/embed/v1/place?key=${import.meta.env.PUBLIC_GOOGLE_API_KEY}&q=Oat+Cafe+Wellington`}
      class="rounded-3xl bg-white shadow"
      allowfullscreen
    >
    </iframe>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      class="mx-auto flex w-full max-w-lg flex-col gap-4"
      data-astro-reload
    >
      <ContactForm client:visible />

      <div>
        <!--<Label htmlFor="email" className="required">Email <span>*</span></Label>-->
        <Input
          type="email"
          id="email"
          name="email"
          data-testid="email-input"
          required
        />
      </div>

      <div>
        <!-- <Label htmlFor="message" className="required"
          >Message <span>*</span></Label
        >-->
        <Textarea
          id="message"
          name="message"
          rows={4}
          data-testid="message-textarea"
          required
        />
      </div>

      <Button type="submit" className="self-end" data-testid="submit-button">
        Get in touch
      </Button>
    </form>
  </div>
</Layout>

<style>
  span {
    color: red;
  }
</style>
